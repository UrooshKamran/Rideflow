<%- include('../partials/header') %>
<div class="container">
    <div class="page-header">
        <h1><i class="fas fa-ticket-alt"></i> Promo Codes</h1>
    </div>
    <%- include('../partials/flash') %>

    <!-- Create Promo -->
    <div class="card">
        <div class="card-header"><h2>Create Promo Code</h2></div>
        <form action="/admin/promos" method="POST" class="auth-form">
            <div class="form-row">
                <div class="form-group">
                    <label>Code</label>
                    <input type="text" name="code" required placeholder="RIDE20" style="text-transform:uppercase;"/>
                </div>
                <div class="form-group">
                    <label>Discount %</label>
                    <input type="number" name="discount_pct" min="1" max="100" required placeholder="20"/>
                </div>
                <div class="form-group">
                    <label>Usage Limit</label>
                    <input type="number" name="usage_limit" min="1" required placeholder="100"/>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>Valid From</label>
                    <input type="datetime-local" name="valid_from" required/>
                </div>
                <div class="form-group">
                    <label>Valid Until</label>
                    <input type="datetime-local" name="valid_until" required/>
                </div>
            </div>
            <button type="submit" class="btn btn-primary">Create Promo</button>
        </form>
    </div>

    <!-- Promo List -->
    <div class="card">
        <div class="card-header"><h2>All Promo Codes</h2></div>
        <% if (promos.length === 0) { %>
            <div class="empty-state"><p>No promo codes yet.</p></div>
        <% } else { %>
        <table class="table">
            <thead>
                <tr>
                    <th>Code</th><th>Discount</th><th>Used</th>
                    <th>Limit</th><th>Valid From</th><th>Valid Until</th><th>Status</th>
                </tr>
            </thead>
            <tbody>
            <% promos.forEach(p => { %>
            <%
                const now = new Date();
                const until = new Date(p.valid_until);
                const isExpired = until < now || p.usage_count >= p.usage_limit;
            %>
            <tr class="<%= isExpired ? 'row-muted' : '' %>">
                <td><strong><%= p.code %></strong></td>
                <td><%= p.discount_pct %>%</td>
                <td><%= p.usage_count %></td>
                <td><%= p.usage_limit %></td>
                <td><%= new Date(p.valid_from).toLocaleDateString() %></td>
                <td><%= new Date(p.valid_until).toLocaleDateString() %></td>
                <td>
                    <% if (isExpired) { %>
                        <span class="badge badge-cancelled">Expired</span>
                    <% } else { %>
                        <span class="badge badge-completed">Active</span>
                    <% } %>
                </td>
            </tr>
            <% }) %>
            </tbody>
        </table>
        <% } %>
    </div>
</div>
<%- include('../partials/footer') %>
